            <div className="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center text-white font-black text-2xl shadow-2xl shadow-indigo-200">G</div>
            <div className="leading-none">
              <p className="font-black text-xl tracking-tighter text-slate-900">GCX Change</p>
              <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-0.5">Enablement Suite</p>
            </div>
          </div>
          
          <nav className="space-y-1.5">
            <SidebarItem icon={LayoutDashboard} label="Dashboard" active={activeTab === 'dashboard'} onClick={() => setActiveTab('dashboard')} />
            <SidebarItem icon={PlusCircle} label="Change Intake" active={activeTab === 'intake'} onClick={() => setActiveTab('intake')} />
            <SidebarItem icon={FileText} label="Active Portfolio" active={activeTab === 'my-changes'} onClick={() => setActiveTab('my-changes')} />
            <SidebarItem icon={BookOpen} label="Toolkit Library" active={activeTab === 'toolkit'} onClick={() => setActiveTab('toolkit')} />
            
            <div className="pt-10">
              <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 px-3">Leadership Command</p>
              <SidebarItem icon={Users} label="Manager Hub" active={activeTab === 'manager-hub'} onClick={() => setActiveTab('manager-hub')} />
              <SidebarItem icon={BarChart3} label="Analytics" active={activeTab === 'analytics'} onClick={() => setActiveTab('analytics')} />
            </div>
          </nav>
        </div>
        
        <div className="mt-auto p-6 border-t border-slate-50 bg-slate-50/30">
          <div className="p-4 bg-white border border-slate-100 rounded-[1.5rem] flex items-center gap-4 shadow-sm">
            <div className="w-12 h-12 rounded-2xl bg-indigo-50 border border-indigo-100 flex items-center justify-center text-indigo-600 font-bold shadow-inner">
               <UserCircle size={28} />
            </div>
            <div className="flex-1 min-w-0">
              <p className="text-xs font-black text-slate-900 truncate tracking-tight">Alex Thompson</p>
              <p className="text-[9px] font-black text-slate-400 uppercase tracking-widest truncate">{role}</p>
            </div>
            <button className="text-slate-300 hover:text-slate-600 transition-colors"><Settings size={18} /></button>
          </div>
        </div>
      </aside>

      {/* Primary Workspace */}
      <main className="flex-1 flex flex-col relative overflow-hidden">
        <header className="h-20 border-b border-slate-200 bg-white/80 backdrop-blur-xl flex items-center justify-between px-10 z-10 shrink-0">
          <div className="flex items-center gap-6">
            <div className="bg-slate-100 p-1.5 rounded-full flex border border-slate-200 shadow-inner">
              {['Leader', 'Manager', 'Change Lead'].map(r => (
                <button
                  key={r} onClick={() => setRole(r)}
                  className={`px-6 py-2 rounded-full text-[10px] font-black uppercase tracking-widest transition-all ${role === r ? 'bg-white text-indigo-600 shadow-md scale-[1.02]' : 'text-slate-500 hover:text-slate-800'}`}
                >
                  {r}
                </button>
              ))}
            </div>
          </div>

          <div className="flex items-center gap-5">
            <button 
               onClick={() => setShowAi(!showAi)} 
               className="flex items-center gap-3 px-5 py-2.5 bg-indigo-50 text-indigo-700 rounded-2xl text-[10px] font-black uppercase tracking-widest border border-indigo-100 transition-all hover:bg-indigo-100 active:scale-95 group"
            >
              <Zap size={16} fill="currentColor" className="group-hover:scale-110 transition-transform" /> 
              AI Assistant
            </button>
            <div className="h-6 w-[1px] bg-slate-200 mx-1"></div>
            <button className="p-2 text-slate-400 hover:text-indigo-600 transition-colors relative">
               <Bell size={22} />
               <div className="absolute top-1.5 right-1.5 w-2.5 h-2.5 bg-rose-500 border-2 border-white rounded-full"></div>
            </button>
            <button className="p-2 text-slate-400 hover:text-indigo-600 transition-colors"><HelpCircle size={22} /></button>
          </div>
        </header>

        {/* Dynamic Canvas Area */}
        <div className="flex-1 overflow-y-auto p-10 lg:p-14 bg-[#F9FAFB]/50">
          {renderContent()}
        </div>

        {/* AI STRATEGY DRAWER */}
        {showAi && (
          <div className="absolute top-20 right-0 bottom-0 w-96 bg-white border-l border-slate-200 shadow-[0_0_100px_rgba(0,0,0,0.1)] z-30 animate-in slide-in-from-right duration-500 flex flex-col">
            <div className="p-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/80">
              <div className="flex items-center gap-3">
                <Sparkles size={20} className="text-indigo-600" />
                <span className="font-black text-sm tracking-tight uppercase text-slate-800">Change Enablement AI</span>
              </div>
              <button onClick={() => setShowAi(false)} className="text-slate-300 hover:text-slate-900 text-3xl font-light leading-none transition-colors">&times;</button>
            </div>
            <div className="flex-1 overflow-y-auto p-6 space-y-6">
              <div className="p-5 bg-indigo-600 text-white rounded-[1.5rem] rounded-tl-none shadow-xl text-xs leading-relaxed font-medium shadow-indigo-200">
                Hi Alex! I've analyzed the current portfolio. <strong>October 15th</strong> is looking risky. Would you like me to simulate a staggered rollout for "Project Phoenix"?
              </div>
              <div className="space-y-3">
                <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Intelligent Actions</p>
                {[
                  { l: "Draft Comms Pack", i: FileText },
                  { l: "Run Collision Scan", i: AlertCircle },
                  { l: "Analyze Sentiment", i: ThumbsUp },
                  { l: "Tiering Recommendation", i: ShieldCheck }
                ].map((p, i) => (
                  <button key={i} className="w-full text-left p-4 rounded-2xl border border-slate-100 hover:bg-indigo-50 hover:border-indigo-100 transition-all text-xs font-black text-slate-700 shadow-sm flex items-center justify-between group">
                    <div className="flex items-center gap-3">
                       <p.i size={16} className="text-indigo-500 group-hover:scale-110 transition-transform" />
                       {p.l}
                    </div>
                    <ChevronRight size={14} className="text-slate-300" />
                  </button>
                ))}
              </div>
            </div>
            <div className="p-6 border-t border-slate-100">
              <div className="relative group">
                <input 
                  type="text" 
                  placeholder="Ask for strategy help..." 
                  className="w-full pl-5 pr-12 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-sm font-medium focus:ring-4 focus:ring-indigo-50 focus:border-indigo-500 outline-none transition-all group-hover:border-slate-300" 
                />
                <button className="absolute right-4 top-1/2 -translate-y-1/2 text-indigo-600 hover:scale-110 transition-transform"><ArrowRight size={22} /></button>
              </div>
            </div>
          </div>
        )}
      </main>
    </div>
  );
}
