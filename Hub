                      <button 
                        key={metric.l} onClick={() => handleMetricToggle(metric.l)}
                        className={`p-5 rounded-2xl border-2 flex flex-col items-center gap-3 transition-all ${formData.metrics.includes(metric.l) ? 'bg-indigo-50 border-indigo-600 ring-4 ring-indigo-50 shadow-inner' : 'bg-white border-slate-100 hover:border-slate-200'}`}
