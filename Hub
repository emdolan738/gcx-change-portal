 * STRATEGIC INTAKE VIEW (The Designer)
 */
const IntakeView = ({ onComplete }) => {
  const [step, setStep] = useState(1);
  const [formData, setFormData] = useState({ 
    title: "", 
    objective: "",
    type: "Technology", 
    audience: 150, 
    complexity: 3, 
    before: "", 
    after: "", 
    goLive: "2024-11-15",
    managerEngagement: [],
    metrics: []
  });

  // 1. SMART IMPACT SCORING
  const impactScore = useMemo(() => {
    let score = (formData.complexity * 15);
    if (formData.audience > 500) score += 20;
    else if (formData.audience > 100) score += 10;
    if (formData.type === "Policy") score += 10;
    if (formData.managerEngagement.length > 2) score += 5;
    return Math.min(score, 100);
  }, [formData]);

  // 2. AUTO-TIERING LOGIC
  const tier = useMemo(() => {
    if (impactScore > 75) return { l: "Tier A", v: "danger", desc: "High-touch support. Full Change Enablement orchestration required." };
    if (impactScore > 45) return { l: "Tier B", v: "warning", desc: "Guided support. Standardized toolkits and consulting." };
    return { l: "Tier C", v: "success", desc: "Self-service enablement. Automated resource access." };
  }, [impactScore]);

  // 3. COLLISION CHECKING (Simulated)
  const collisionDetected = formData.goLive === "2024-10-15" || formData.goLive === "2024-11-15";

  // 4. MANAGER EFFORT CALCULATION
  const managerEffort = useMemo(() => {
    const taskCount = formData.managerEngagement.length;
    if (taskCount > 3 || formData.complexity >= 4) return { l: "High", v: "danger" };
    if (taskCount > 1) return { l: "Medium", v: "warning" };
    return { l: "Low", v: "success" };
